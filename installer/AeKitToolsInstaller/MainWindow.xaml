<Window x:Class="AeKitToolsInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AeToolsKit Installer"
        Width="1240"
        Height="780"
        MinWidth="1080"
        MinHeight="700"
        Icon="Assets/AeKitTools.ico"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanMinimize"
        Loaded="Window_Loaded">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF0B1016" Offset="0" />
            <GradientStop Color="#FF121923" Offset="0.52" />
            <GradientStop Color="#FF0E141C" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PrimaryActionBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF33B6FF" Offset="0" />
            <GradientStop Color="#FF0A84FF" Offset="1" />
        </LinearGradientBrush>

        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFF5F7FB" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FFBCC5D2" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#FF8792A4" />
        <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#22FFFFFF" />
        <SolidColorBrush x:Key="SoftSurfaceBorderBrush" Color="#14FFFFFF" />

        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#78141C26" />
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="28" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="InsetCardStyle" TargetType="Border" BasedOn="{StaticResource GlassCardStyle}">
            <Setter Property="Background" Value="#4D18212D" />
            <Setter Property="BorderBrush" Value="{StaticResource SoftSurfaceBorderBrush}" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="PillBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#14FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,10,10" />
        </Style>

        <Style x:Key="WindowActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#14FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChromeBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChromeBorder" Property="Background" Value="#1FFFFFFF" />
                                <Setter TargetName="ChromeBorder" Property="BorderBrush" Value="#30FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ChromeBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryActionBrush}" />
            <Setter Property="BorderBrush" Value="#22000000" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Segoe UI Semibold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="MinHeight" Value="54" />
            <Setter Property="MinWidth" Value="220" />
            <Setter Property="Padding" Value="24,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PrimaryBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PrimaryBorder" Property="Opacity" Value="0.94" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PrimaryBorder" Property="Opacity" Value="0.84" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PrimaryBorder" Property="Opacity" Value="0.48" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#16FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Segoe UI Semibold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="54" />
            <Setter Property="MinWidth" Value="136" />
            <Setter Property="Padding" Value="22,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SecondaryBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SecondaryBorder" Property="Background" Value="#22FFFFFF" />
                                <Setter TargetName="SecondaryBorder" Property="BorderBrush" Value="#32FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SecondaryBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusCardStyle" TargetType="Border" BasedOn="{StaticResource InsetCardStyle}">
            <Setter Property="BorderBrush" Value="#22FFFFFF" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusTone}" Value="working">
                    <Setter Property="Background" Value="#331E3A53" />
                    <Setter Property="BorderBrush" Value="#5533B6FF" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="success">
                    <Setter Property="Background" Value="#3322362B" />
                    <Setter Property="BorderBrush" Value="#5549D17D" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="error">
                    <Setter Property="Background" Value="#333B2024" />
                    <Setter Property="BorderBrush" Value="#55F87171" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PreviewToolStyle" TargetType="Border">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="CheckBorder"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="6"
                                    BorderBrush="{StaticResource SurfaceBorderBrush}"
                                    BorderThickness="1"
                                    Background="#12FFFFFF"
                                    VerticalAlignment="Center">
                                <Path x:Name="CheckGlyph"
                                      Data="M 4 9 L 8 13 L 14 5"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed" />
                            </Border>

                            <ContentPresenter Grid.Column="1"
                                              Margin="10,0,0,0"
                                              VerticalAlignment="Center" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#33FFFFFF" />
                                <Setter TargetName="CheckBorder" Property="Background" Value="#18FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#660A84FF" />
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#990A84FF" />
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CheckBorder" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="6" />
            <Setter Property="Background" Value="#1AFFFFFF" />
            <Setter Property="Foreground" Value="#FF0A84FF" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="420"
                     Height="420"
                     Canvas.Left="-110"
                     Canvas.Top="-110"
                     Opacity="0.75">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="0.35,0.35">
                        <GradientStop Color="#8C0A84FF" Offset="0" />
                        <GradientStop Color="#000A84FF" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="72" />
                </Ellipse.Effect>
            </Ellipse>

            <Ellipse Width="360"
                     Height="360"
                     Canvas.Right="-60"
                     Canvas.Bottom="-70"
                     Opacity="0.55">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="0.45,0.45">
                        <GradientStop Color="#6637C8FF" Offset="0" />
                        <GradientStop Color="#0037C8FF" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="68" />
                </Ellipse.Effect>
            </Ellipse>

            <Ellipse Width="260"
                     Height="260"
                     Canvas.Left="420"
                     Canvas.Top="520"
                     Opacity="0.24">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="0.5,0.5">
                        <GradientStop Color="#55FFFFFF" Offset="0" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="54" />
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <Border Margin="18"
                Background="{StaticResource WindowBackgroundBrush}"
                BorderBrush="#26FFFFFF"
                BorderThickness="1"
                CornerRadius="34">
            <Border.Effect>
                <DropShadowEffect BlurRadius="46"
                                  ShadowDepth="18"
                                  Opacity="0.42"
                                  Color="#FF000000" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Margin="30,24,24,0"
                      MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Width="46"
                                Height="46"
                                CornerRadius="23"
                                Margin="0,0,14,0"
                                Background="{StaticResource PrimaryActionBrush}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="26"
                                                  ShadowDepth="8"
                                                  Opacity="0.24"
                                                  Color="#FF0A84FF" />
                            </Border.Effect>
                            <Grid>
                                <Ellipse Width="18"
                                         Height="18"
                                         Fill="#CCFFFFFF"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Top"
                                         Margin="11,9,0,0" />
                                <Ellipse Width="10"
                                         Height="10"
                                         Fill="#55FFFFFF"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Bottom"
                                         Margin="0,0,11,10" />
                            </Grid>
                        </Border>

                        <StackPanel>
                            <TextBlock Text="AeToolsKit Installer"
                                       FontFamily="Segoe UI Semibold"
                                       FontSize="16"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Executavel com deploy GitHub e visual glass"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">
                        <Button Content="&#x2212;"
                                Style="{StaticResource WindowActionButtonStyle}"
                                Margin="0,0,8,0"
                                Click="MinimizeButton_Click" />
                        <Button Content="&#x00D7;"
                                Style="{StaticResource WindowActionButtonStyle}"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1"
                      Margin="30,24,30,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.98*" />
                        <ColumnDefinition Width="1.12*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel x:Name="HeroPanel"
                                Margin="0,0,28,0"
                                Opacity="0">
                        <Border Padding="12,8"
                                Background="#16FFFFFF"
                                BorderBrush="{StaticResource SurfaceBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock Text="Novo layout do instalador"
                                       FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </Border>

                        <TextBlock Margin="0,22,0,0"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="54"
                                   FontWeight="SemiBold"
                                   LineHeight="60"
                                   TextWrapping="Wrap">
                            <Run Text="Atualize o " Foreground="{StaticResource TextPrimaryBrush}" />
                            <Run Text="AeToolsKit" Foreground="#FF33B6FF" />
                            <LineBreak />
                            <Run Text="com o visual novo." Foreground="{StaticResource TextPrimaryBrush}" />
                        </TextBlock>

                        <TextBlock Margin="0,18,0,0"
                                   FontSize="16"
                                   LineHeight="25"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap">
                            Este executavel instala a extensao no CEP global, baixa o payload do GitHub quando disponivel e agora acompanha o mesmo idioma visual glass do painel.
                        </TextBlock>

                        <WrapPanel Margin="0,24,0,0">
                            <Border Style="{StaticResource PillBorderStyle}">
                                <TextBlock Text="Atualizacao 1 clique"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </Border>
                            <Border Style="{StaticResource PillBorderStyle}">
                                <TextBlock Text="GitHub + fallback local"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </Border>
                            <Border Style="{StaticResource PillBorderStyle}">
                                <TextBlock Text="CEP debug opcional"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </Border>
                        </WrapPanel>

                        <Border Margin="0,32,0,0"
                                Style="{StaticResource GlassCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Preview do pacote"
                                           FontSize="12"
                                           Foreground="#FF33B6FF" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="O instalador e o painel agora seguem a mesma linguagem visual."
                                           FontFamily="Segoe UI Semibold"
                                           FontSize="24"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextWrapping="Wrap" />

                                <Grid Margin="0,20,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="72"
                                            Padding="11,12"
                                            Background="#8211171E"
                                            BorderBrush="{StaticResource SurfaceBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="22">
                                        <StackPanel HorizontalAlignment="Center">
                                            <Border Style="{StaticResource PreviewToolStyle}">
                                                <TextBlock Text="▤"
                                                           FontSize="16"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                            </Border>
                                            <Border Style="{StaticResource PreviewToolStyle}">
                                                <TextBlock Text="✕"
                                                           FontSize="15"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                            </Border>
                                            <Border Style="{StaticResource PreviewToolStyle}">
                                                <TextBlock Text="◉"
                                                           FontSize="15"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                            </Border>
                                            <Border Style="{StaticResource PreviewToolStyle}">
                                                <TextBlock Text="▣"
                                                           FontSize="15"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                            </Border>
                                            <Border Style="{StaticResource PreviewToolStyle}"
                                                    Background="#18FFFFFF">
                                                <TextBlock Text="⬛"
                                                           FontSize="14"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                            </Border>
                                            <Border Width="34"
                                                    Height="34"
                                                    CornerRadius="10"
                                                    Background="Transparent">
                                                <TextBlock Text="⛁"
                                                           FontSize="14"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <Grid Grid.Column="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                Margin="0,0,0,12"
                                                Style="{StaticResource InsetCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Painel atualizado"
                                                           FontFamily="Segoe UI Semibold"
                                                           FontSize="16"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="O css novo da extensao ja entra no payload local embutido e tambem sera o modelo consumido do GitHub."
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="1"
                                                Margin="0,0,0,12"
                                                Style="{StaticResource InsetCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Fluxo de entrega"
                                                           FontFamily="Segoe UI Semibold"
                                                           FontSize="16"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="1. Baixa do GitHub. 2. Cai para o pacote local se necessario. 3. Publica no CEP global."
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="2"
                                                Style="{StaticResource InsetCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Destino final"
                                                           FontFamily="Segoe UI Semibold"
                                                           FontSize="16"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="%CommonProgramFiles(x86)%\Adobe\CEP\extensions\AeKitTools"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border x:Name="ActionPanel"
                                Style="{StaticResource GlassCardStyle}"
                                Opacity="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <ScrollViewer Grid.Row="0"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel>
                                        <TextBlock Text="Executavel"
                                                   FontSize="12"
                                                   Foreground="#FF33B6FF" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="Instalacao sincronizada com o GitHub."
                                                   FontFamily="Segoe UI Semibold"
                                                   FontSize="26"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="O instalador detecta o ambiente, pede UAC quando necessario e regrava a extensao global com o layout mais recente."
                                                   FontSize="14"
                                                   LineHeight="22"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextSecondaryBrush}" />

                                        <Border Margin="0,18,0,0"
                                                Style="{StaticResource StatusCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding StatusTitle}"
                                                           FontFamily="Segoe UI Semibold"
                                                           FontSize="18"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="{Binding StatusMessage}"
                                                           FontSize="14"
                                                           LineHeight="22"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Border>

                                        <Grid Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Margin="0,0,8,0"
                                                    Style="{StaticResource InsetCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Modo"
                                                               FontSize="12"
                                                               Foreground="#FF33B6FF" />
                                                    <TextBlock Margin="0,8,0,0"
                                                               Text="{Binding InstallationBadgeText}"
                                                               FontFamily="Segoe UI Semibold"
                                                               FontSize="16"
                                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="Substitui a versao anterior no CEP global com sobrescrita segura."
                                                               TextWrapping="Wrap"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Margin="8,0,0,0"
                                                    Style="{StaticResource InsetCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Payload"
                                                               FontSize="12"
                                                               Foreground="#FF33B6FF" />
                                                    <TextBlock Margin="0,8,0,0"
                                                               Text="{Binding PayloadSummary}"
                                                               FontFamily="Segoe UI Semibold"
                                                               FontSize="16"
                                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="GitHub primeiro, pacote local embutido como fallback."
                                                               TextWrapping="Wrap"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Border Margin="0,18,0,0"
                                                Style="{StaticResource InsetCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Ambiente detectado"
                                                           FontSize="12"
                                                           Foreground="#FF33B6FF" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="{Binding DetectionSummary}"
                                                           FontFamily="Segoe UI Semibold"
                                                           FontSize="16"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Margin="0,14,0,0"
                                                           Text="Destino de instalacao"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="{Binding InstallPath}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />

                                                <TextBlock Margin="0,14,0,0"
                                                           Text="Instalacoes detectadas"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}" />

                                                <ItemsControl Margin="0,10,0,0"
                                                              ItemsSource="{Binding AfterEffectsVersions}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{StaticResource PillBorderStyle}">
                                                                <TextBlock Text="{Binding}"
                                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Text="{Binding EnvironmentNote}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Visibility="{Binding ShowEnvironmentNote, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="0,18,0,0"
                                                Style="{StaticResource InsetCardStyle}">
                                            <StackPanel>
                                                <CheckBox Content="Habilitar PlayerDebugMode do CEP automaticamente"
                                                          IsChecked="{Binding EnableDebugMode, Mode=TwoWay}" />
                                                <TextBlock Margin="28,8,0,0"
                                                           Text="Recomendado para extensoes sem assinatura abrirem no After Effects."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="0,18,0,0"
                                                Style="{StaticResource InsetCardStyle}">
                                            <TextBlock Text="Depois de instalar, abra ou reinicie o After Effects e procure por AeToolsKit em Janela > Extensoes."
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>

                                <ProgressBar Grid.Row="1"
                                             Margin="0,14,0,0"
                                             IsIndeterminate="True"
                                             Visibility="{Binding IsInstalling, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                <Grid Grid.Row="2"
                                      Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Content="{Binding InstallButtonText}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            IsEnabled="{Binding IsReadyToInstall}"
                                            Click="InstallButton_Click" />

                                    <Button Grid.Column="1"
                                            Margin="12,0,0,0"
                                            Content="Abrir CEP"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="OpenExtensionsRootButton_Click" />

                                    <Button Grid.Column="2"
                                            Margin="12,0,0,0"
                                            Content="Ver pasta"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="OpenInstallPathButton_Click" />
                                </Grid>
                            </Grid>
                        </Border>

                        <Border x:Name="FooterPanel"
                                Grid.Row="1"
                                Margin="0,18,0,0"
                                Style="{StaticResource InsetCardStyle}"
                                Opacity="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Width="52"
                                        Height="52"
                                        CornerRadius="18"
                                        Background="#16FFFFFF"
                                        BorderBrush="{StaticResource SurfaceBorderBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Path Data="M 12 30 L 24 14 L 39 24 L 24 38 Z"
                                              Stroke="#FF33B6FF"
                                              StrokeThickness="2"
                                              Fill="Transparent"
                                              Stretch="Uniform"
                                              Margin="12" />
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Margin="18,0,0,0">
                                    <TextBlock Text="Pronto para publicar no GitHub"
                                               FontFamily="Segoe UI Semibold"
                                               FontSize="16"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="O layout novo do painel ja esta no repositorio local e sera o mesmo consumido pelo instalador assim que o update for para a branch principal."
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
