<Window x:Class="AeKitToolsInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AeToolsKit Installer"
        Width="1180"
        Height="760"
        MinWidth="1020"
        MinHeight="700"
        Icon="Assets/AeKitTools.ico"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanMinimize"
        Loaded="Window_Loaded">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF7FBFF" Offset="0" />
            <GradientStop Color="#FFF0F5FC" Offset="0.58" />
            <GradientStop Color="#FFEAF0F8" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PrimaryActionBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF0F9CE8" Offset="0" />
            <GradientStop Color="#FF3ACBAA" Offset="1" />
        </LinearGradientBrush>

        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF0F172A" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF526178" />
        <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#66FFFFFF" />

        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#BFFFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="26" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="InsetCardStyle" TargetType="Border" BasedOn="{StaticResource GlassCardStyle}">
            <Setter Property="Background" Value="#99FFFFFF" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="WindowActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#88FFFFFF" />
            <Setter Property="BorderBrush" Value="#1F0F172A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChromeBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChromeBorder" Property="Background" Value="#FFFFFFFF" />
                                <Setter TargetName="ChromeBorder" Property="BorderBrush" Value="#33193A5A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ChromeBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryActionBrush}" />
            <Setter Property="BorderBrush" Value="#33000000" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MinHeight" Value="54" />
            <Setter Property="MinWidth" Value="210" />
            <Setter Property="Padding" Value="24,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PrimaryBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PrimaryBorder" Property="Opacity" Value="0.94" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PrimaryBorder" Property="Opacity" Value="0.86" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PrimaryBorder" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#CCFFFFFF" />
            <Setter Property="BorderBrush" Value="#1A0F172A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="54" />
            <Setter Property="MinWidth" Value="132" />
            <Setter Property="Padding" Value="22,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SecondaryBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SecondaryBorder" Property="Background" Value="#FFFFFFFF" />
                                <Setter TargetName="SecondaryBorder" Property="BorderBrush" Value="#25193A5A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SecondaryBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusCardStyle" TargetType="Border" BasedOn="{StaticResource InsetCardStyle}">
            <Setter Property="BorderBrush" Value="#160F172A" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusTone}" Value="working">
                    <Setter Property="Background" Value="#FFF0F9FF" />
                    <Setter Property="BorderBrush" Value="#5520A4F3" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="success">
                    <Setter Property="Background" Value="#FFF0FDF6" />
                    <Setter Property="BorderBrush" Value="#5534D399" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="error">
                    <Setter Property="Background" Value="#FFFFF4F4" />
                    <Setter Property="BorderBrush" Value="#55FB7185" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="6" />
            <Setter Property="Background" Value="#1A0F172A" />
            <Setter Property="Foreground" Value="#FF22B8CF" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="360"
                     Height="360"
                     Canvas.Left="-88"
                     Canvas.Top="-70"
                     Opacity="0.8">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="0.35,0.35">
                        <GradientStop Color="#8022B8CF" Offset="0" />
                        <GradientStop Color="#0022B8CF" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="60" />
                </Ellipse.Effect>
            </Ellipse>

            <Ellipse Width="300"
                     Height="300"
                     Canvas.Right="-34"
                     Canvas.Bottom="-52"
                     Opacity="0.75">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="0.4,0.4">
                        <GradientStop Color="#6634D399" Offset="0" />
                        <GradientStop Color="#0034D399" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="54" />
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <Border Margin="18"
                Background="{StaticResource WindowBackgroundBrush}"
                BorderBrush="#B2FFFFFF"
                BorderThickness="1"
                CornerRadius="32">
            <Border.Effect>
                <DropShadowEffect BlurRadius="50"
                                  ShadowDepth="18"
                                  Opacity="0.18"
                                  Color="#FF0F172A" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Margin="28,22,22,0"
                      MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Width="42"
                                Height="42"
                                CornerRadius="21"
                                Margin="0,0,14,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF0F9CE8" Offset="0" />
                                    <GradientStop Color="#FF34D399" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="22"
                                                  ShadowDepth="8"
                                                  Opacity="0.18"
                                                  Color="#FF0F9CE8" />
                            </Border.Effect>
                            <Grid>
                                <Ellipse Width="18"
                                         Height="18"
                                         Fill="#CCFFFFFF"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Top"
                                         Margin="10,8,0,0" />
                                <Ellipse Width="10"
                                         Height="10"
                                         Fill="#55FFFFFF"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Bottom"
                                         Margin="0,0,11,10" />
                            </Grid>
                        </Border>

                        <StackPanel>
                            <TextBlock Text="AeToolsKit Installer"
                                       FontFamily="Bahnschrift"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Deploy premium para o painel do After Effects"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">
                        <Button Content="&#8211;"
                                Style="{StaticResource WindowActionButtonStyle}"
                                Margin="0,0,8,0"
                                Click="MinimizeButton_Click" />
                        <Button Content="X"
                                Style="{StaticResource WindowActionButtonStyle}"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1"
                      Margin="30,24,30,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.02*" />
                        <ColumnDefinition Width="1.18*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel x:Name="HeroPanel"
                                Margin="0,0,28,0"
                                Opacity="0">
                        <Border Padding="12,8"
                                Background="#99FFFFFF"
                                BorderBrush="#66FFFFFF"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock Text="GitHub-backed installer"
                                       FontFamily="Bahnschrift"
                                       FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </Border>

                        <TextBlock Margin="0,22,0,0"
                                   FontFamily="Bahnschrift"
                                   FontSize="54"
                                   FontWeight="SemiBold"
                                   LineHeight="60"
                                   TextWrapping="Wrap">
                            <Run Text="Instale o " Foreground="{StaticResource TextPrimaryBrush}" />
                            <Run Text="AeToolsKit" Foreground="#FF0F9CE8" />
                            <LineBreak />
                            <Run Text="com visual de produto." Foreground="{StaticResource TextPrimaryBrush}" />
                        </TextBlock>

                        <TextBlock Margin="0,18,0,0"
                                   FontSize="16"
                                   LineHeight="25"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap">
                            O executavel baixa a extensao direto do GitHub, pede permissao de administrador no clique de instalar e publica o painel no CEP global do Windows.
                        </TextBlock>

                        <WrapPanel Margin="0,24,0,0">
                            <Border Margin="0,0,10,10"
                                    Padding="14,8"
                                    Background="#CCFFFFFF"
                                    BorderBrush="#1A0F172A"
                                    BorderThickness="1"
                                    CornerRadius="999">
                                <TextBlock Text="1 clique"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </Border>
                            <Border Margin="0,0,10,10"
                                    Padding="14,8"
                                    Background="#CCFFFFFF"
                                    BorderBrush="#1A0F172A"
                                    BorderThickness="1"
                                    CornerRadius="999">
                                <TextBlock Text="CEP debug opcional"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </Border>
                            <Border Margin="0,0,10,10"
                                    Padding="14,8"
                                    Background="#CCFFFFFF"
                                    BorderBrush="#1A0F172A"
                                    BorderThickness="1"
                                    CornerRadius="999">
                                <TextBlock Text="{Binding PayloadSummary}"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </Border>
                        </WrapPanel>

                        <Border Margin="0,34,0,0"
                                Style="{StaticResource GlassCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Fluxo do instalador"
                                           FontFamily="Bahnschrift"
                                           FontSize="12"
                                           Foreground="#FF0F9CE8" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="Tres etapas para colocar o painel no ar."
                                           FontFamily="Bahnschrift"
                                           FontSize="24"
                                           Foreground="{StaticResource TextPrimaryBrush}" />

                                <Grid Margin="0,22,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0"
                                            Margin="0,0,0,12"
                                            Style="{StaticResource InsetCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="01"
                                                       FontFamily="Bahnschrift"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FF0F9CE8" />
                                            <StackPanel Grid.Column="1"
                                                        Margin="18,0,0,0">
                                                <TextBlock Text="Download do GitHub"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Text="O instalador busca o pacote mais recente do repositório e separa apenas os arquivos da extensao."
                                                           Margin="0,4,0,0"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1"
                                            Margin="0,0,0,12"
                                            Style="{StaticResource InsetCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="02"
                                                       FontFamily="Bahnschrift"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FF34D399" />
                                            <StackPanel Grid.Column="1"
                                                        Margin="18,0,0,0">
                                                <TextBlock Text="Instalacao no CEP global"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Text="O painel vai para %CommonProgramFiles(x86)%\Adobe\CEP\extensions\AeKitTools com sobrescrita segura."
                                                           Margin="0,4,0,0"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="2"
                                            Style="{StaticResource InsetCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="03"
                                                       FontFamily="Bahnschrift"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FFF97316" />
                                            <StackPanel Grid.Column="1"
                                                        Margin="18,0,0,0">
                                                <TextBlock Text="AE pronto para abrir o painel"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Text="Se o debug estiver ativo, a extensao aparece no menu do After Effects apos reiniciar o app."
                                                           Margin="0,4,0,0"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="0" />
                        </Grid.RowDefinitions>

                        <Border x:Name="ActionPanel"
                                Style="{StaticResource GlassCardStyle}"
                                Opacity="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <ScrollViewer Grid.Row="0"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel>
                                        <TextBlock Text="Deploy controlado"
                                                   FontFamily="Bahnschrift"
                                                   FontSize="12"
                                                   Foreground="#FF0F9CE8" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="Tudo que voce precisa para instalar o painel."
                                                   FontFamily="Bahnschrift"
                                                   FontSize="24"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="O instalador detecta o ambiente, baixa do GitHub, pede UAC quando necessario e instala para todos os usuarios."
                                                   FontSize="14"
                                                   LineHeight="21"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextSecondaryBrush}" />

                                        <Border Margin="0,18,0,0"
                                                Style="{StaticResource StatusCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding StatusTitle}"
                                                           FontFamily="Bahnschrift"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="{Binding StatusMessage}"
                                                           FontSize="14"
                                                           LineHeight="22"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Border>

                                        <Grid Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Margin="0,0,8,0"
                                                    Style="{StaticResource InsetCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Modo de instalacao"
                                                               FontSize="12"
                                                               Foreground="#FF0F9CE8" />
                                                    <TextBlock Margin="0,8,0,0"
                                                               Text="{Binding InstallationBadgeText}"
                                                               FontFamily="Bahnschrift"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="Substitui a versao anterior no CEP global."
                                                               TextWrapping="Wrap"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Margin="8,0,0,0"
                                                    Style="{StaticResource InsetCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="After Effects"
                                                               FontSize="12"
                                                               Foreground="#FF0F9CE8" />
                                                    <TextBlock Margin="0,8,0,0"
                                                               Text="{Binding DetectionSummary}"
                                                               FontFamily="Bahnschrift"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Border Margin="0,18,0,0"
                                                Style="{StaticResource InsetCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Destino"
                                                           FontSize="12"
                                                           Foreground="#FF0F9CE8" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="{Binding InstallPath}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Margin="0,12,0,0"
                                                           Text="Instalacoes detectadas"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />

                                                <ItemsControl Margin="0,10,0,0"
                                                              ItemsSource="{Binding AfterEffectsVersions}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,0,10,10"
                                                                    Padding="12,7"
                                                                    Background="#CCFFFFFF"
                                                                    BorderBrush="#140F172A"
                                                                    BorderThickness="1"
                                                                    CornerRadius="14">
                                                                <TextBlock Text="{Binding}"
                                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Text="{Binding EnvironmentNote}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap"
                                                           Visibility="{Binding ShowEnvironmentNote, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            </StackPanel>
                                        </Border>

                                        <StackPanel Margin="0,18,0,0">
                                            <CheckBox Content="Habilitar PlayerDebugMode do CEP automaticamente"
                                                      IsChecked="{Binding EnableDebugMode, Mode=TwoWay}" />
                                            <TextBlock Margin="28,8,0,0"
                                                       Text="Recomendado para extensoes sem assinatura abrirem no After Effects."
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <Border Margin="0,18,0,0"
                                                Style="{StaticResource InsetCardStyle}">
                                            <TextBlock Text="Depois de instalar, abra ou reinicie o After Effects e procure por AeToolsKit em Janela > Extensoes."
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>

                                <ProgressBar Grid.Row="1"
                                             Margin="0,14,0,0"
                                             IsIndeterminate="True"
                                             Visibility="{Binding IsInstalling, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                <Grid Grid.Row="2"
                                      Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Content="{Binding InstallButtonText}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            IsEnabled="{Binding IsReadyToInstall}"
                                            Click="InstallButton_Click" />

                                    <Button Grid.Column="1"
                                            Margin="12,0,0,0"
                                            Content="Abrir CEP"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="OpenExtensionsRootButton_Click" />

                                    <Button Grid.Column="2"
                                            Margin="12,0,0,0"
                                            Content="Ver pasta"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="OpenInstallPathButton_Click" />
                                </Grid>
                            </Grid>
                        </Border>

                        <Border x:Name="FooterPanel"
                                Grid.Row="1"
                                Margin="0,18,0,0"
